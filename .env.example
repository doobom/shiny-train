# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Allowed origins for CORS (Server deployment)
ALLOWED_ORIGINS="http://localhost:5173,https://my-vercel-app.vercel.app"

# Base URL for API calls from the frontend to the backend
VITE_API_BASE_URL="https://my-backend.vps.com"

# Which frontend to render: 'user', 'admin', or 'both'
VITE_APP_MODE="both"

# Notification Settings (Resend / Emails)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Cloud Storage (Cloudflare R2 - Used for File Uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
PASSWORD_SALT="my_secret_salt_here"

# Initial Super Admin User (used during database seeding via /api/admin/init-db)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="super_secure_password"

# PII Master Encryption Key
# MUST be exactly 32 characters long. Used for AES-256-CBC encryption of sensitive data (e.g. phone numbers, addresses).
# WARNING: If this changes, previously encrypted data will become unreadable!
ENCRYPTION_KEY="your_32_character_encryption_key"
VITE_B_FRONTEND_URL=
VITE_C_FRONTEND_URL=
